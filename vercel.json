{
    "rewrites": [
        {
            "source": "/api/ixc/:path*",
            "destination": "https://us-central1-avl-telecom.cloudfunctions.net/ixcProxy/:path*"
        },
        {
            "source": "/api/smartolt/:path*",
            "destination": "/api/smartolt"
        },
        {
            "source": "/webhook/whatsapp",
            "destination": "/api/whatsapp-webhook"
        },
        {
            "source": "/api/whapi/:path*",
            "destination": "https://gate.whapi.cloud/:path*"
        },
        {
            "source": "/api/whatsapp-cdn/:path*",
            "destination": "https://pps.whatsapp.net/:path*"
        },
        {
            "source": "/(.*)",
            "destination": "/"
        }
    ]
}