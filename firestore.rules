rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Permitir acesso total à collection "chat" e suas subcollections
    match /chat/{document=**} {
      allow read, write: if true;
    }
    
    // Regras específicas para subcollections de mensagens
    match /chat/{clienteId}/mensagens/{mensagemId} {
      allow read, write: if true;
    }

    // Regras para Sorteios Pagos (Públicos)
    match /paid_raffles/{raffleId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    match /paid_raffle_tickets/{ticketId} {
      allow read: if true; // Permite buscar bilhetes por CPF/whatsapp no cliente
      allow write: if request.auth != null;
    }
    
    match /paid_raffle_payments/{paymentId} {
      allow read: if true; // Permite o cliente escutar a confirmação do pagamento em tempo real
      allow write: if request.auth != null;
    }
    
    match /users/{document=**} {
      allow read, write: if true;
    }
    
    match /usuariosDoPreMix/{document=**} {
      allow read, write: if true;
    }
    
    match /referralCodes/{document=**} {
      allow read, write: if true;
    }
    
    match /pre_mix_roulette_wins/{document=**} {
      allow read, write: if true;
    }

    match /pre_mix_roulette_items/{document=**} {
      allow read, write: if true;
    }

    // Regras padrão para outras collections
    match /{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
} 